{
  "name": "loop",
  "version": "1.0.14",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build --compile --outfile loop src/cli.ts",
    "install:global": "bun run build && bun run src/install.ts",
    "release:patch": "npm version patch && git push --follow-tags",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "bin": {
    "loop": "./src/cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^25.3.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.3"
  }
}
